<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no" />
  <title>プロ級 牧羊犬ゲーム</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      overflow: hidden;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0d1726;
      color: #f0f4f8;
    }

    #gameContainer {
      position: relative;
      width: 100%;
      height: 100%;
      background:
        radial-gradient(circle at 50% 28%, rgba(49, 88, 138, 0.28), transparent 42%),
        radial-gradient(circle at 50% 50%, #1d3353 0%, #12233d 50%, #0d1726 100%);
    }

    canvas {
      display: block;
      width: 100%;
      height: calc(100% - 72px);
      touch-action: none;
    }

    #hud {
      position: absolute;
      left: 0;
      bottom: 0;
      width: 100%;
      height: 72px;
      background: rgba(7, 13, 24, 0.94);
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: space-around;
      gap: 10px;
      padding: 0 12px;
      box-sizing: border-box;
      backdrop-filter: blur(8px);
    }

    #hud span {
      min-width: 72px;
      font-size: 14px;
      opacity: 0.95;
    }

    #messageLabel {
      flex: 1;
      text-align: center;
      color: #9fe8ff;
      font-weight: 700;
    }

    .hud-btn {
      background: #214d7a;
      border: none;
      color: #f0f4f8;
      padding: 8px 12px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 700;
    }

    #settingsPanel {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 220px;
      background: rgba(7, 13, 24, 0.94);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 12px;
      z-index: 20;
      display: none;
      box-shadow: 0 10px 30px rgba(0,0,0,0.25);
      backdrop-filter: blur(8px);
    }

    #settingsPanel.open {
      display: block;
    }

    #settingsPanel strong {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
    }

    #settingsPanel label {
      display: block;
      margin: 10px 0 4px;
      font-size: 12px;
      opacity: 0.9;
    }

    #settingsPanel input[type="range"] {
      width: 100%;
    }

    #settingsPanel button {
      margin-top: 10px;
      width: 100%;
      padding: 8px;
      background: #214d7a;
      border: none;
      color: #f0f4f8;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 700;
    }

    #overlay {
      position: absolute;
      inset: 0 0 72px 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 18px;
      background: rgba(8, 15, 28, 0.86);
      z-index: 30;
      text-align: center;
      padding: 20px;
      box-sizing: border-box;
    }

    #overlay.hidden {
      display: none;
    }

    #overlayText {
      font-size: 34px;
      font-weight: 800;
      letter-spacing: 0.03em;
      color: #f6fbff;
      text-shadow: 0 6px 24px rgba(0,0,0,0.25);
    }

    #overlaySub {
      font-size: 14px;
      color: rgba(255,255,255,0.75);
      max-width: 340px;
      line-height: 1.6;
    }

    #overlayButton {
      padding: 10px 24px;
      font-size: 16px;
      font-weight: 800;
      border: none;
      border-radius: 12px;
      background: linear-gradient(180deg, #39c6ff, #178fcb);
      color: #071521;
      cursor: pointer;
      box-shadow: 0 10px 24px rgba(23,143,203,0.3);
    }
  </style>
</head>
<body>
  <div id="gameContainer">
    <canvas id="gameCanvas"></canvas>

    <div id="settingsPanel">
      <strong>調整</strong>

      <label for="dogSpeed">犬スピード</label>
      <input type="range" id="dogSpeed" min="80" max="320" value="170" />

      <label for="maxStage">最大ステージ</label>
      <input type="range" id="maxStage" min="1" max="7" value="5" />

      <label for="fearDist">羊の犬回避距離</label>
      <input type="range" id="fearDist" min="80" max="220" value="155" />

      <button id="closeSettings">閉じる</button>
    </div>

    <div id="overlay">
      <div id="overlayText">牧羊犬ゲーム</div>
      <div id="overlaySub">羊を自分で操作するのではなく、牧羊犬が群れをまとめてゴールへ押し込む様子を眺めるゲームです。</div>
      <button id="overlayButton">開始</button>
    </div>

    <div id="hud">
      <span id="stageLabel">Stage: 1</span>
      <span id="sheepCountLabel">Sheep: 1</span>
      <span id="messageLabel"></span>
      <button id="settingsToggle" class="hud-btn">設定</button>
    </div>
  </div>

  <script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');

    const stageLabel = document.getElementById('stageLabel');
    const sheepCountLabel = document.getElementById('sheepCountLabel');
    const messageLabel = document.getElementById('messageLabel');

    const settingsPanel = document.getElementById('settingsPanel');
    const settingsToggle = document.getElementById('settingsToggle');
    const closeSettings = document.getElementById('closeSettings');

    const dogSpeedSlider = document.getElementById('dogSpeed');
    const maxStageSlider = document.getElementById('maxStage');
    const fearDistSlider = document.getElementById('fearDist');

    const overlay = document.getElementById('overlay');
    const overlayText = document.getElementById('overlayText');
    const overlaySub = document.getElementById('overlaySub');
    const overlayButton = document.getElementById('overlayButton');

    const params = {
      sheepMinSpeed: 26,
      sheepMaxSpeed: 78,
      separationDist: 24,
      cohesionDist: 96,
      alignmentDist: 68,
      separationStrength: 0.045,
      cohesionStrength: 0.008,
      alignmentStrength: 0.06,

      fearDist: 155,
      fearStrength: 52,

      dogSpeed: 170,
      dogAcceleration: 8.5,
      strayThreshold: 120,
      driveDistance: 98,
      collectDistance: 74,
      sideAmplitude: 36,
      sideFrequency: 1.15,

      goalRadius: 76,
      goalStayTime: 0.55,
      maxStage: 5
    };

    let cw = 0;
    let ch = 0;
    let dpr = 1;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      cw = window.innerWidth;
      ch = window.innerHeight - 72;

      canvas.width = Math.floor(cw * dpr);
      canvas.height = Math.floor(ch * dpr);
      canvas.style.width = cw + 'px';
      canvas.style.height = ch + 'px';

      if (typeof ctx.resetTransform === 'function') {
        ctx.resetTransform();
      } else {
        ctx.setTransform(1, 0, 0, 1, 0, 0);
      }
      ctx.scale(dpr, dpr);
    }

    window.addEventListener('resize', resize);

    function clamp(v, min, max) {
      return Math.max(min, Math.min(max, v));
    }

    function lerp(a, b, t) {
      return a + (b - a) * t;
    }

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function dist(x1, y1, x2, y2) {
      return Math.hypot(x2 - x1, y2 - y1);
    }

    class Sheep {
      constructor(x, y, vx = null, vy = null) {
        this.x = x;
        this.y = y;
        this.r = 7.2;
        this.vx = vx ?? rand(-1, 1) * params.sheepMaxSpeed;
        this.vy = vy ?? rand(-1, 1) * params.sheepMaxSpeed;
        this.wobble = Math.random() * Math.PI * 2;
      }

      update(dt, sheepList, dog, goal) {
        let ax = 0;
        let ay = 0;

        let cx = 0;
        let cy = 0;
        let cCount = 0;

        let avx = 0;
        let avy = 0;
        let aCount = 0;

        for (const other of sheepList) {
          if (other === this) continue;
          const dx = other.x - this.x;
          const dy = other.y - this.y;
          const d2 = dx * dx + dy * dy;

          if (d2 < params.separationDist * params.separationDist && d2 > 0.0001) {
            const d = Math.sqrt(d2);
            const strength = (1 - d / params.separationDist) * params.separationStrength * 100;
            ax -= (dx / d) * strength;
            ay -= (dy / d) * strength;
          }

          if (d2 < params.cohesionDist * params.cohesionDist) {
            cx += other.x;
            cy += other.y;
            cCount++;
          }

          if (d2 < params.alignmentDist * params.alignmentDist) {
            avx += other.vx;
            avy += other.vy;
            aCount++;
          }
        }

        if (cCount > 0) {
          cx /= cCount;
          cy /= cCount;
          ax += (cx - this.x) * params.cohesionStrength * 60;
          ay += (cy - this.y) * params.cohesionStrength * 60;
        }

        if (aCount > 0) {
          avx /= aCount;
          avy /= aCount;
          ax += (avx - this.vx) * params.alignmentStrength;
          ay += (avy - this.vy) * params.alignmentStrength;
        }

        const ddx = this.x - dog.x;
        const ddy = this.y - dog.y;
        const dDog = Math.hypot(ddx, ddy);
        if (dDog < params.fearDist) {
          const strength = (1 - dDog / params.fearDist) * params.fearStrength;
          ax += (ddx / Math.max(0.001, dDog)) * strength;
          ay += (ddy / Math.max(0.001, dDog)) * strength;
        }

        const margin = 28;
        if (this.x < margin) ax += (margin - this.x) * 8;
        if (this.x > cw - margin) ax -= (this.x - (cw - margin)) * 8;
        if (this.y < margin) ay += (margin - this.y) * 8;
        if (this.y > ch - margin) ay -= (this.y - (ch - margin)) * 8;

        const gx = goal.x - this.x;
        const gy = goal.y - this.y;
        const gDist = Math.hypot(gx, gy);
        if (gDist < goal.r) {
          this.vx *= 0.93;
          this.vy *= 0.93;
          ax += gx * 0.7;
          ay += gy * 0.7;
        }

        this.vx += ax * dt;
        this.vy += ay * dt;

        const speed = Math.hypot(this.vx, this.vy);
        if (speed > params.sheepMaxSpeed) {
          this.vx = (this.vx / speed) * params.sheepMaxSpeed;
          this.vy = (this.vy / speed) * params.sheepMaxSpeed;
        } else if (speed < params.sheepMinSpeed) {
          const target = params.sheepMinSpeed / Math.max(0.001, speed);
          this.vx *= target;
          this.vy *= target;
        }

        this.vx *= 0.985;
        this.vy *= 0.985;

        this.x += this.vx * dt;
        this.y += this.vy * dt;

        this.x = clamp(this.x, this.r, cw - this.r);
        this.y = clamp(this.y, this.r, ch - this.r);

        this.wobble += dt * 8;
      }

      draw(ctx) {
        ctx.save();
        ctx.translate(this.x, this.y);

        const angle = Math.atan2(this.vy, this.vx || 0.001);
        ctx.rotate(angle);

        ctx.fillStyle = 'rgba(0,0,0,0.18)';
        ctx.beginPath();
        ctx.ellipse(0, this.r + 2, this.r * 0.95, this.r * 0.42, 0, 0, Math.PI * 2);
        ctx.fill();

        const body = ctx.createRadialGradient(-2, -2, 1, 0, 0, this.r);
        body.addColorStop(0, '#ffffff');
        body.addColorStop(1, '#d7dde6');
        ctx.fillStyle = body;
        ctx.beginPath();
        ctx.arc(0, 0, this.r, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = '#9aa6b8';
        ctx.beginPath();
        ctx.ellipse(-this.r * 0.45, -this.r * 0.62, this.r * 0.22, this.r * 0.36, -0.25, 0, Math.PI * 2);
        ctx.ellipse(this.r * 0.45, -this.r * 0.62, this.r * 0.22, this.r * 0.36, 0.25, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = '#6f7f92';
        ctx.beginPath();
        ctx.arc(this.r * 0.15, -this.r * 0.06, this.r * 0.16, 0, Math.PI * 2);
        ctx.fill();

        ctx.restore();
      }
    }

    class Dog {
      constructor(x, y) {
        this.x = x;
        this.y = y;
        this.vx = 0;
        this.vy = 0;
        this.targetX = x;
        this.targetY = y;
        this.sidePhase = Math.random() * Math.PI * 2;
        this.state = 'collect';
      }

      update(dt, sheepList, goal) {
        if (!sheepList.length) return;

        let centerX = 0;
        let centerY = 0;
        for (const s of sheepList) {
          centerX += s.x;
          centerY += s.y;
        }
        centerX /= sheepList.length;
        centerY /= sheepList.length;

        let stray = sheepList[0];
        let maxDist = -1;
        for (const s of sheepList) {
          const d = dist(s.x, s.y, centerX, centerY);
          if (d > maxDist) {
            maxDist = d;
            stray = s;
          }
        }

        if (maxDist > params.strayThreshold) {
          this.state = 'collect';
        } else {
          const toGoalX = goal.x - centerX;
          const toGoalY = goal.y - centerY;
          const gLen = Math.hypot(toGoalX, toGoalY) || 1;
          const gx = toGoalX / gLen;
          const gy = toGoalY / gLen;

          let orientSum = 0;
          for (const s of sheepList) {
            const sp = Math.hypot(s.vx, s.vy) || 1;
            orientSum += (s.vx / sp) * gx + (s.vy / sp) * gy;
          }
          const orientAvg = orientSum / sheepList.length;
          this.state = sheepList.length > 2 && orientAvg < 0.6 ? 'orient' : 'drive';
        }

        if (this.state === 'collect') {
          const toCenterX = centerX - stray.x;
          const toCenterY = centerY - stray.y;
          const len = Math.hypot(toCenterX, toCenterY) || 1;
          const nx = toCenterX / len;
          const ny = toCenterY / len;

          this.targetX = stray.x - nx * params.collectDistance;
          this.targetY = stray.y - ny * params.collectDistance;
        } else {
          const toGoalX = goal.x - centerX;
          const toGoalY = goal.y - centerY;
          const len = Math.hypot(toGoalX, toGoalY) || 1;
          const nx = toGoalX / len;
          const ny = toGoalY / len;

          let dynamicDist = params.driveDistance;
          const preferred = len - goal.r * 1.2;
          const minDist = params.goalRadius * 0.75;
          if (preferred < dynamicDist) dynamicDist = Math.max(minDist, preferred);
          if (this.state === 'orient') dynamicDist *= 1.35;

          this.sidePhase += dt * params.sideFrequency * Math.PI * 2;
          const perpX = -ny;
          const perpY = nx;
          const amp = this.state === 'orient' ? params.sideAmplitude * 1.5 : params.sideAmplitude;
          const sideOffset = Math.sin(this.sidePhase) * amp;

          this.targetX = centerX - nx * dynamicDist + perpX * sideOffset;
          this.targetY = centerY - ny * dynamicDist + perpY * sideOffset;
        }

        this.targetX = clamp(this.targetX, 16, cw - 16);
        this.targetY = clamp(this.targetY, 16, ch - 16);

        const dx = this.targetX - this.x;
        const dy = this.targetY - this.y;
        const len = Math.hypot(dx, dy) || 1;
        const dirX = dx / len;
        const dirY = dy / len;

        const targetVx = dirX * params.dogSpeed;
        const targetVy = dirY * params.dogSpeed;

        this.vx += (targetVx - this.vx) * clamp(params.dogAcceleration * dt, 0, 1);
        this.vy += (targetVy - this.vy) * clamp(params.dogAcceleration * dt, 0, 1);

        this.x += this.vx * dt;
        this.y += this.vy * dt;

        this.x = clamp(this.x, 0, cw);
        this.y = clamp(this.y, 0, ch);
      }

      draw(ctx) {
        ctx.save();
        ctx.translate(this.x, this.y);
        const angle = Math.atan2(this.vy, this.vx || 0.001);
        ctx.rotate(angle);

        const size = 13;

        ctx.fillStyle = 'rgba(0,0,0,0.20)';
        ctx.beginPath();
        ctx.ellipse(0, size * 0.55, size * 0.7, size * 0.28, 0, 0, Math.PI * 2);
        ctx.fill();

        ctx.beginPath();
        ctx.moveTo(size, 0);
        ctx.lineTo(-size * 0.65, -size * 0.62);
        ctx.lineTo(-size * 0.65, size * 0.62);
        ctx.closePath();
        ctx.fillStyle = '#ff944d';
        ctx.fill();

        ctx.fillStyle = '#284f73';
        ctx.beginPath();
        ctx.ellipse(-size * 0.18, 0, size * 0.38, size * 0.36, 0, 0, Math.PI * 2);
        ctx.fill();

        ctx.restore();
      }
    }

    class Goal {
      constructor(x, y, r) {
        this.x = x;
        this.y = y;
        this.r = r;
      }

      draw(ctx, pulse = 0) {
        const ring = ctx.createRadialGradient(this.x, this.y, this.r * 0.45, this.x, this.y, this.r * (1.2 + pulse * 0.15));
        ring.addColorStop(0, 'rgba(0,255,200,0.08)');
        ring.addColorStop(1, 'rgba(0,255,200,0.65)');

        ctx.lineWidth = 6;
        ctx.strokeStyle = ring;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r * (1 + pulse * 0.08), 0, Math.PI * 2);
        ctx.stroke();

        ctx.fillStyle = 'rgba(0,255,200,0.045)';
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r * 0.92, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    const game = {
      sheep: [],
      dog: null,
      goal: null,
      stage: 1,
      state: 'start',
      inGoalTime: 0,
      lastTime: 0,
      messageTimer: 0,
      particles: []
    };

    function updateHUD() {
      stageLabel.textContent = `Stage: ${game.stage}`;
      sheepCountLabel.textContent = `Sheep: ${game.sheep.length}`;
    }

    function showMessage(text, duration = 1.6) {
      messageLabel.textContent = text;
      game.messageTimer = duration;
    }

    function showOverlay(title, sub, buttonText, onClick) {
      overlayText.textContent = title;
      overlaySub.textContent = sub || '';
      overlayButton.textContent = buttonText;
      overlay.classList.remove('hidden');
      overlayButton.onclick = () => {
        overlay.classList.add('hidden');
        onClick?.();
      };
    }

    function randomGoalPosition() {
      const margin = params.goalRadius + 42;
      return {
        x: rand(margin, cw - margin),
        y: rand(margin, ch * 0.42)
      };
    }

    function initGame() {
      resize();

      params.dogSpeed = parseFloat(dogSpeedSlider.value);
      params.maxStage = parseInt(maxStageSlider.value, 10);
      params.fearDist = parseFloat(fearDistSlider.value);

      game.stage = 1;
      game.state = 'play';
      game.inGoalTime = 0;
      game.messageTimer = 0;
      game.particles = [];

      const startX = cw * 0.5;
      const startY = ch * 0.8;

      game.sheep = [new Sheep(startX, startY)];
      game.dog = new Dog(cw * 0.5, ch * 0.93);

      const gp = randomGoalPosition();
      game.goal = new Goal(gp.x, gp.y, params.goalRadius);

      updateHUD();
      showMessage('ステージ1');
    }

    function spawnParticles(x, y, count, color = 'rgba(0,255,200,0.8)') {
      for (let i = 0; i < count; i++) {
        const a = Math.random() * Math.PI * 2;
        const speed = rand(40, 180);
        game.particles.push({
          x, y,
          vx: Math.cos(a) * speed,
          vy: Math.sin(a) * speed,
          life: rand(0.3, 0.9),
          maxLife: 0,
          size: rand(1.5, 3.5),
          color
        });
        game.particles[game.particles.length - 1].maxLife = game.particles[game.particles.length - 1].life;
      }
    }

    function nextStage() {
      const nextSheep = [];

      for (const s of game.sheep) {
        const offset = 10;
        const left = new Sheep(s.x - offset, s.y);
        const right = new Sheep(s.x + offset, s.y);

        let speedLen = Math.hypot(s.vx, s.vy);
        if (speedLen < 1) {
          const angle = Math.random() * Math.PI * 2;
          speedLen = (params.sheepMinSpeed + params.sheepMaxSpeed) * 0.5;

          left.vx = Math.cos(angle) * speedLen;
          left.vy = Math.sin(angle) * speedLen;
          right.vx = Math.cos(angle + Math.PI) * speedLen;
          right.vy = Math.sin(angle + Math.PI) * speedLen;
        } else {
          left.vx = -s.vy;
          left.vy = s.vx;
          right.vx = s.vy;
          right.vy = -s.vx;
        }

        for (const ns of [left, right]) {
          const sp = Math.hypot(ns.vx, ns.vy) || 1;
          if (sp < params.sheepMinSpeed) {
            ns.vx = (ns.vx / sp) * params.sheepMinSpeed;
            ns.vy = (ns.vy / sp) * params.sheepMinSpeed;
          } else if (sp > params.sheepMaxSpeed) {
            ns.vx = (ns.vx / sp) * params.sheepMaxSpeed;
            ns.vy = (ns.vy / sp) * params.sheepMaxSpeed;
          }
        }

        nextSheep.push(left, right);
      }

      game.sheep = nextSheep;
      game.stage += 1;
      game.inGoalTime = 0;

      const gp = randomGoalPosition();
      game.goal.x = gp.x;
      game.goal.y = gp.y;

      game.dog.x = cw * 0.5;
      game.dog.y = ch * 0.93;
      game.dog.vx = 0;
      game.dog.vy = 0;
      game.dog.state = 'collect';
      game.dog.sidePhase = Math.random() * Math.PI * 2;

      updateHUD();
      showMessage(`分裂 → ステージ${game.stage}`);
      spawnParticles(game.goal.x, game.goal.y, 22, 'rgba(255,255,255,0.85)');
    }

    function updateParticles(dt) {
      for (let i = game.particles.length - 1; i >= 0; i--) {
        const p = game.particles[i];
        p.life -= dt;
        p.x += p.vx * dt;
        p.y += p.vy * dt;
        p.vy += 120 * dt;
        p.vx *= 0.985;
        p.vy *= 0.985;

        if (p.life <= 0) {
          game.particles.splice(i, 1);
        }
      }
    }

    function drawParticles() {
      for (const p of game.particles) {
        const alpha = clamp(p.life / p.maxLife, 0, 1);
        ctx.globalAlpha = alpha;
        ctx.fillStyle = p.color;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }

    function drawBackground() {
      const grad = ctx.createLinearGradient(0, 0, 0, ch);
      grad.addColorStop(0, 'rgba(255,255,255,0.02)');
      grad.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, cw, ch);

      ctx.strokeStyle = 'rgba(255,255,255,0.025)';
      ctx.lineWidth = 1;
      for (let i = 0; i < 18; i++) {
        const y = (i + 1) * (ch / 18);
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(cw, y);
        ctx.stroke();
      }
    }

    function loop(timestamp) {
      if (!game.lastTime) game.lastTime = timestamp;
      const dt = Math.min((timestamp - game.lastTime) / 1000, 0.033);
      game.lastTime = timestamp;

      ctx.clearRect(0, 0, cw, ch);
      drawBackground();

      if (game.goal) {
        const pulse = game.inGoalTime > 0 ? clamp(game.inGoalTime / params.goalStayTime, 0, 1) : 0;
        game.goal.draw(ctx, pulse);
      }

      if (game.state === 'play' && game.dog && game.goal) {
        for (const s of game.sheep) {
          s.update(dt, game.sheep, game.dog, game.goal);
        }

        game.dog.update(dt, game.sheep, game.goal);

        let allInGoal = true;
        for (const s of game.sheep) {
          const dx = s.x - game.goal.x;
          const dy = s.y - game.goal.y;
          if (dx * dx + dy * dy > game.goal.r * game.goal.r) {
            allInGoal = false;
            break;
          }
        }

        if (allInGoal && game.sheep.length > 0) {
          game.inGoalTime += dt;

          if (game.inGoalTime > params.goalStayTime) {
            spawnParticles(game.goal.x, game.goal.y, 26, 'rgba(0,255,200,0.85)');

            if (game.stage >= params.maxStage) {
              game.state = 'gameOver';
              showOverlay(
                'コンプリート！',
                'すべてのステージをクリアしました。もう一度最初から遊べます。',
                'もう一度',
                () => {
                  initGame();
                }
              );
            } else {
              nextStage();
            }
          }
        } else {
          game.inGoalTime = 0;
        }
      }

      updateParticles(dt);

      for (const s of game.sheep) s.draw(ctx);
      if (game.dog) game.dog.draw(ctx);
      drawParticles();

      if (game.messageTimer > 0) {
        game.messageTimer -= dt;
        if (game.messageTimer <= 0) {
          messageLabel.textContent = '';
        }
      }

      requestAnimationFrame(loop);
    }

    settingsToggle.addEventListener('click', () => {
      settingsPanel.classList.toggle('open');
    });

    closeSettings.addEventListener('click', () => {
      settingsPanel.classList.remove('open');
    });

    dogSpeedSlider.addEventListener('input', () => {
      params.dogSpeed = parseFloat(dogSpeedSlider.value);
    });

    maxStageSlider.addEventListener('input', () => {
      params.maxStage = parseInt(maxStageSlider.value, 10);
    });

    fearDistSlider.addEventListener('input', () => {
      params.fearDist = parseFloat(fearDistSlider.value);
    });

    window.addEventListener('DOMContentLoaded', () => {
      resize();
      requestAnimationFrame(loop);

      showOverlay(
        '牧羊犬ゲーム',
        '犬が羊の群れをまとめてゴールへ押し込みます。全頭が入ると羊が分裂して次のステージへ進みます。',
        '開始',
        () => {
          initGame();
        }
      );
    });
  </script>
</body>
</html>
